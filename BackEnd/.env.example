# Backend Environment Variables
# Copia este archivo a .env y completa con tus valores

# Puerto del servidor
PORT=3000

# Secreto para firmar tokens JWT (mínimo 32 caracteres, puede ser cualquier cadena aleatoria)
JWT_SECRET=tu_clave_secreta_aqui_min_32_caracteres

# ─── Base de Datos ────────────────────────────────────────────────────────────

# Dialecto: "mysql" (local/TiDB) o "postgres" (Render, Supabase, etc.)
DB_DIALECT=mysql

# Opción A: Variables individuales (MySQL local o TiDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_contraseña_mysql
DB_DATABASE=clinica_db
# Activar SSL para bases de datos remotas como TiDB Cloud
DB_SSL=false

# Opción B: URL de conexión (Postgres en Render u otros)
# Si DB_DIALECT=postgres y DATABASE_URL está definida, se usa esta en su lugar.
# DATABASE_URL=postgresql://usuario:contraseña@host/nombre_db

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Obtén la contraseña de aplicación en: https://myaccount.google.com/apppasswords
# Si no se configura, se usará una cuenta de prueba Ethereal en modo desarrollo.
EMAIL_USER=tu_email@gmail.com
DB_EMAILPASS=tu_contraseña_app_gmail
# Opcional: nombre y dirección que aparece como remitente
# EMAIL_FROM=Sanatorio UTN <utnsanatorio@gmail.com>
